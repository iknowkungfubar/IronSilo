# IronSilo Production Configuration Example
# Copy this file to .env and modify as needed

# ===================
# CORE SETTINGS
# ===================
IRONSILO_API_KEY=your-secret-api-key-here
ENVIRONMENT=production
CORS_ORIGINS=https://app.example.com

# ===================
# DATABASE
# ===================
POSTGRES_DB=ironsilo_vault
POSTGRES_USER=silo_admin
POSTGRES_PASSWORD=use-a-secure-password-here

# ===================
# LLM CONFIGURATION
# ===================
# Point to your local LLM server (LM Studio, Ollama, etc.)
LLM_ENDPOINT=http://host.docker.internal:8000/v1/chat/completions

# Compression settings
COMPRESSION_THRESHOLD=1000
COMPRESSION_RATE=0.6

# Retry settings
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY=1.0
RETRY_MAX_DELAY=10.0

# Circuit breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=30.0

# ===================
# RATE LIMITING
# ===================
RATE_LIMIT_REQUESTS=60
MAX_REQUEST_SIZE=10485760

# ===================
# SWARM SERVICE
# ===================
CDP_URL=ws://browser-node:9222
OPENAI_API_BASE=http://llm-proxy:8001/api/v1
GENESYS_URL=http://genesys-memory:8000