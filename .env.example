# ============================================
# IronSilo Environment Configuration
# ============================================
# Copy this file to .env and update values
# NEVER commit .env to version control

# ============================================
# PostgreSQL Database
# ============================================
POSTGRES_DB=ironsilo_vault
POSTGRES_USER=silo_admin
# REQUIRED: Set a strong password
POSTGRES_PASSWORD=change_me_to_a_strong_password

# ============================================
# LLM Proxy
# ============================================
# Endpoint for your local LLM (LM Studio, Ollama, etc.)
LLM_ENDPOINT=http://host.docker.internal:8000/v1/chat/completions

# API Key for authenticating requests (leave empty to disable auth)
IRONSILO_API_KEY=

# Traefik auth token — must match the Authorization: Bearer <token>
# sent by clients. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED for production deployments.
SILO_AUTH_TOKEN=

# Rate limiting (requests per minute)
RATE_LIMIT_REQUESTS=60

# Environment (development or production)
ENVIRONMENT=production

# CORS origins (comma-separated for production)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ============================================
# Genesys Memory
# ============================================
GENESYS_BACKEND=postgres
GENESYS_EMBEDDER=local

# ============================================
# MCP Servers
# ============================================
MCP_SERVER_TYPE=genesys
GENESYS_API_URL=http://genesys-memory:8000
KHOJ_API_URL=http://khoj:42110

# ============================================
# SearXNG
# ============================================
# SECURITY: Generate a random key with: python3 -c "import secrets; print(secrets.token_hex(32))"
SEARXNG_SECRET_KEY=

# ============================================
# Security Notes
# ============================================
# 1. Always set POSTGRES_PASSWORD in production
# 2. Set IRONSILO_API_KEY to enable API-level authentication
# 3. Set SILO_AUTH_TOKEN in .env for Traefik edge auth
# 4. Set SEARXNG_SECRET_KEY in .env for SearXNG (generate with secrets.token_hex(32))
# 5. In production, set ENVIRONMENT=production
# 6. Specify CORS_ORIGINS for your frontend domain
# ============================================
